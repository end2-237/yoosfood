# Supabase (exposé au navigateur)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Accès admin NeonX (pages /neonx-admin/*)
NEXT_PUBLIC_ADMIN_PASS=neonx123

# Configuration NeonX (routes /api/neonx/*)
DB_TYPE=mongodb
DB_HOST=localhost
DB_PORT=27017
DB_NAME=neonx_db
FEATURE_AUTH=false
FEATURE_DASHBOARD=false
FEATURE_FORMS=false
FEATURE_NOTIFICATIONS=false
